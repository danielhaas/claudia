#!/usr/bin/env bash
# claudia-manager - Manage Claude Code tmux sessions on the desktop
# Used both locally and remotely (via SSH from mobile)

set -euo pipefail

TMUX_CONF="${HOME}/.config/claudia/tmux.conf"
SESSION_PREFIX="claude"

# Get next available session number
next_session_number() {
    local max=-1
    while IFS= read -r name; do
        if [[ "$name" =~ ^${SESSION_PREFIX}-([0-9]+)$ ]]; then
            local num="${BASH_REMATCH[1]}"
            (( num > max )) && max=$num
        fi
    done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)
    echo $(( max + 1 ))
}

# List all claude tmux sessions with metadata
cmd_list() {
    if ! tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -q "^${SESSION_PREFIX}-"; then
        echo "NO_SESSIONS"
        return
    fi

    local format="#{session_name}|#{session_created}|#{pane_current_path}|#{pane_current_command}|#{window_width}x#{window_height}"
    tmux list-sessions -F "$format" 2>/dev/null | while IFS='|' read -r name created path cmd size; do
        if [[ "$name" =~ ^${SESSION_PREFIX}- ]]; then
            local age
            age=$(( $(date +%s) - created ))
            local human_age
            if (( age < 60 )); then
                human_age="${age}s"
            elif (( age < 3600 )); then
                human_age="$(( age / 60 ))m"
            elif (( age < 86400 )); then
                human_age="$(( age / 3600 ))h"
            else
                human_age="$(( age / 86400 ))d"
            fi

            # Try to get last few lines of pane content for preview
            local preview
            preview=$(tmux capture-pane -t "$name" -p 2>/dev/null | grep -v '^$' | tail -1 | cut -c1-60)
            [[ -z "$preview" ]] && preview="(no output)"

            echo "${name}|${human_age}|${path}|${preview}"
        fi
    done
}

# Create a new claude session
cmd_new() {
    local dir="${1:-$HOME}"
    local num
    num=$(next_session_number)
    local session_name="${SESSION_PREFIX}-${num}"

    if [[ -f "$TMUX_CONF" ]]; then
        tmux -f "$TMUX_CONF" new-session -d -s "$session_name" -c "$dir"
    else
        tmux new-session -d -s "$session_name" -c "$dir"
    fi

    # Start claude in the session
    tmux send-keys -t "$session_name" 'claude' Enter

    echo "$session_name"
}

# Attach to an existing session
cmd_attach() {
    local session_name="$1"
    if tmux has-session -t "$session_name" 2>/dev/null; then
        exec tmux attach-session -t "$session_name"
    else
        echo "ERROR: Session '$session_name' not found" >&2
        exit 1
    fi
}

# Wrap: if not in tmux, create a session and attach. Used as the desktop alias.
cmd_wrap() {
    if [[ -n "${TMUX:-}" ]]; then
        # Already in tmux, just run claude directly
        exec claude "$@"
    fi

    local dir
    dir=$(pwd)
    local num
    num=$(next_session_number)
    local session_name="${SESSION_PREFIX}-${num}"

    if [[ -f "$TMUX_CONF" ]]; then
        tmux -f "$TMUX_CONF" new-session -d -s "$session_name" -c "$dir"
    else
        tmux new-session -d -s "$session_name" -c "$dir"
    fi

    if [[ $# -gt 0 ]]; then
        tmux send-keys -t "$session_name" "claude $*" Enter
    else
        tmux send-keys -t "$session_name" 'claude' Enter
    fi

    exec tmux attach-session -t "$session_name"
}

# Kill a session
cmd_kill() {
    local session_name="$1"
    tmux kill-session -t "$session_name" 2>/dev/null
    echo "Killed $session_name"
}

# Main dispatch
case "${1:-help}" in
    list)    cmd_list ;;
    new)     cmd_new "${2:-}" ;;
    attach)  cmd_attach "${2:?Usage: claudia-manager attach <session-name>}" ;;
    wrap)    shift; cmd_wrap "$@" ;;
    kill)    cmd_kill "${2:?Usage: claudia-manager kill <session-name>}" ;;
    help|*)
        cat <<'EOF'
claudia-manager - Claude Code tmux session manager

Commands:
  list              List active claude sessions
  new [dir]         Create a new claude session (returns session name)
  attach <name>     Attach to a session (interactive)
  wrap [args...]    Wrap claude in a tmux session (desktop alias)
  kill <name>       Kill a session
EOF
        ;;
esac
